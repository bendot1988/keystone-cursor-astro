---
const items = [
	'Dream Home Ideas',
	'Make Overs',
	'DIY Rescues',
	'Getting Ready to Sell',
	'Tenancy Changeovers',
] as const;
---

<section class="complete-solutions" aria-labelledby="complete-solutions-heading">
	<div class="complete-solutions__inner">
		<header class="complete-solutions__header">
			<h2 id="complete-solutions-heading" class="complete-solutions__title type-h2-48-700 kr-motion-enter-fade-up-sm">
				Complete property solutions
			</h2>
			<p class="complete-solutions__subtitle type-large-body-18-400 kr-motion-enter-fade-up-sm kr-motion-delay-1">
				For any style of renovation need
			</p>
		</header>

		<ul class="complete-solutions__list" aria-labelledby="complete-solutions-heading">
			{
				items.map((label, i) => (
					<li
						class:list={[
							'complete-solutions__item',
							'kr-motion-enter-fade-up-sm',
							i % 3 === 1 ? 'kr-motion-delay-1' : undefined,
							i % 3 === 2 ? 'kr-motion-delay-2' : undefined,
						]}
					>
						<span class="complete-solutions__item-text">{label}</span>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.complete-solutions {
		position: relative;
		background: var(--color-white);
		padding: var(--section-pad-y-complete) var(--section-pad-x);
		isolation: isolate;
		overflow: hidden;
	}

	/* Subtle blueprint-style backdrop — placeholder until a real building-plans image is supplied. */
	.complete-solutions::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -1;
		background-image:
			linear-gradient(to right, rgba(28, 50, 71, 0.06) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(28, 50, 71, 0.06) 1px, transparent 1px);
		background-size: 56px 56px, 56px 56px;
		opacity: 0.85;
		pointer-events: none;
	}

	.complete-solutions::after {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -1;
		background: radial-gradient(
			ellipse at 50% 40%,
			rgba(255, 255, 255, 0) 0%,
			rgba(255, 255, 255, 0.7) 60%,
			var(--color-white) 100%
		);
		pointer-events: none;
	}

	.complete-solutions__inner {
		max-width: var(--layout-max-72);
		margin: 0 auto;
	}

	.complete-solutions__header {
		text-align: center;
		max-width: var(--layout-max-48);
		margin: 0 auto 2.75rem;
	}

	.complete-solutions__title {
		margin: 0 0 1rem;
		color: var(--color-dark-gray);
	}

	.complete-solutions__subtitle {
		margin: 0;
		text-align: center;
		font-style: italic;
		color: color-mix(in srgb, var(--color-dark-gray) 70%, var(--color-gray));
	}

	.complete-solutions__list {
		list-style: none;
		margin: 0 auto;
		padding: 0;
		max-width: var(--layout-max-48);
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		align-items: stretch;
	}

	.complete-solutions__item {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem 1.25rem;
		text-align: center;
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1rem, 0.9rem + 0.5vw, 1.25rem);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-dark-gray);
		background: color-mix(in srgb, var(--color-white) 86%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-dark-gray) 12%, var(--color-white));
		border-radius: 6px;
		box-shadow: 0 1px 2px rgba(26, 27, 27, 0.04);
	}

	.complete-solutions__item-text {
		display: inline-block;
	}
</style>
